{
  "active_profile": "local",
  "default_template": "gemini",
  "runtimes": {
    "docker": {
      "host": ""
    },
    "container": {
      "tmux": true
    },
    "kubernetes": {
      "context": "",
      "namespace": ""
    }
  },
  "harnesses": {
    "gemini": {
      "image": "us-central1-docker.pkg.dev/ptone-misc/public-docker/scion-gemini",
      "user": "node"
    },
    "claude": {
      "image": "us-central1-docker.pkg.dev/ptone-misc/public-docker/scion-claude",
      "user": "node"
    },
    "opencode": {
      "image": "us-central1-docker.pkg.dev/user-content-search/public-docker/scion-opencode:latest",
      "user": "node"
    },
    "codex": {
      "image": "us-central1-docker.pkg.dev/user-content-search/public-docker/scion-codex:latest",
      "user": "node"
    }
  },
  "profiles": {
    "local": {
      "runtime": "container",
      "tmux": true
    },
    "remote": {
      "runtime": "kubernetes",
      "tmux": false,
      "harness_overrides": {
        }
    }
  }
}
